---
import Base from "../layouts/Base.astro";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import logoEstRepublicain from "../assets/sponsort/est_republicain.png";
import logoImageEst from "../assets/sponsort/imagest.jpg";
import logoPressePonti from "../assets/sponsort/presse_ponti.png";
import logoSouvenirFr from "../assets/sponsort/souvenir_fr.png";
import logoToutSimplement from "../assets/sponsort/logo_toutsimplement.png";
import logoCinemaOlympia from "../assets/sponsort/cinema_olympia_pontarlier.png";
import logoDeGiorgi from "../assets/sponsort/de_giorgi.png";
import logoIcr from "../assets/sponsort/icr.png";
import logoPontarlier from "../assets/sponsort/pontarlier.png";
import logoMjcCapucins from "../assets/sponsort/2957-3585770933.jpg";

interface Partner {
  name: string;
  url?: string;
  // string = path absolu vers public/ (ex. "/sponsors/foo.svg")
  // ImageMetadata = import depuis src/assets/ (PNG/JPG optimisés par Astro)
  logo?: ImageMetadata | string;
}

const partners: Partner[] = [
  {
    name: "Tout simplement",
    url: "https://www.toutsimplement.com/",
    logo: logoToutSimplement,
  },
  {
    name: "Lombardot",
    url: "https://www.cuisines-lombardot.com/",
    logo: "/sponsors/lombardot.svg",
  },
  {
    name: "De Giorgi",
    url: "https://www.de-giorgi.fr/",
    logo: logoDeGiorgi,
  },
  {
    name: "Cinéma Olympia Pontarlier",
    url: "https://cinema-pontarlier.fr/",
    logo: logoCinemaOlympia,
  },
  { name: "Bulthaup Pontarlier", url: "https://pontarlier.bulthaup.com/fr/" },
  {
    name: "L'Entrepôt du bricolage",
    url: "https://www.entrepot-du-bricolage.fr/mon-magasin/pontarlier",
    logo: "/sponsors/entrepot-bricolage.svg",
  },
  {
    name: "L'Est Républicain",
    url: "https://www.estrepublicain.fr/",
    logo: logoEstRepublicain,
  },
  {
    name: "MJC des Capucins",
    url: "http://www.mjcdescapucins.fr/",
    logo: logoMjcCapucins,
  },
  {
    name: "Institut Catholique de Rennes",
    url: "https://www.icrennes.org/",
    logo: logoIcr,
  },
  {
    name: "Image'Est",
    url: "https://www.image-est.fr/",
    logo: logoImageEst,
  },
  {
    name: "Ville de Pontarlier",
    url: "https://www.ville-pontarlier.fr/",
    logo: logoPontarlier,
  },
  {
    name: "Le Souvenir Français",
    url: "https://le-souvenir-francais.fr/",
    logo: logoSouvenirFr,
  },
  { name: "Parloncap" },
  { name: "Crédit Agricole", url: "https://www.credit-agricole.fr/ca-franchecomte/" },
  {
    name: "La Presse Pontissalienne",
    url: "https://www.presse-pontissalienne.fr/",
    logo: logoPressePonti,
  },
  { name: "SwissLife", url: "https://www.swisslife.fr/" },
  { name: "Gentlemen's Barber Shop", url: "https://www.gentlemens-barbershop.com/" },
  { name: "Commune de Houtaud", url: "https://houtaud.fr/" },
];

const donationUrl = "#";
---

<Base
  title="Nous soutenir"
  description="Soutenez l'association Fortin par un don ou un partenariat. Découvrez nos partenaires actuels qui nous accompagnent dans le devoir de mémoire."
>
  <section class="bg-fortin-green-dark px-8 py-12 text-fortin-beige md:px-16 md:py-16">
    <div class="mx-auto flex max-w-7xl flex-col items-start gap-6 md:flex-row md:items-center md:justify-between md:gap-12">
      <div>
        <h1 class="font-display text-4xl font-bold md:text-5xl">
          Soutenir Fortin
        </h1>
        <p class="mt-4 max-w-2xl text-base md:text-lg">
          Aidez-nous à faire vivre l'association. En faisant une donation, vous
          nous aidez à entretenir l'histoire qui vous passionne.
        </p>
      </div>
      <a
        href={donationUrl}
        class="inline-flex shrink-0 items-center justify-center rounded-sm bg-fortin-beige px-6 py-3 font-medium text-fortin-green-dark transition-opacity hover:opacity-80"
      >
        Faire un don
      </a>
    </div>
  </section>

  <section class="px-8 py-16 md:px-16 md:py-20">
    <div class="mx-auto max-w-7xl">
      <div class="text-center">
        <p class="font-display text-2xl md:text-3xl">
          Ils nous soutiennent déjà&nbsp;!
        </p>
        <p class="mt-2 font-display text-2xl md:text-3xl">Rejoignez-les&nbsp;!</p>
        <hr class="mx-auto mt-8 max-w-3xl border-fortin-green-dark/30" />
      </div>

      <div class="mt-12 grid grid-cols-2 gap-6 md:grid-cols-4 md:gap-10 lg:grid-cols-5">
        {
          partners.map((partner) => {
            const cardClass =
              "flex aspect-square items-center justify-center bg-fortin-green-dark/5 p-4 text-center transition-opacity hover:opacity-70";

            const inner = partner.logo ? (
              typeof partner.logo === "string" ? (
                <img
                  src={partner.logo}
                  alt={`Logo ${partner.name}`}
                  class="max-h-full max-w-full object-contain"
                  loading="lazy"
                />
              ) : (
                <Image
                  src={partner.logo}
                  alt={`Logo ${partner.name}`}
                  class="max-h-full max-w-full object-contain"
                  loading="lazy"
                />
              )
            ) : (
              <p class="text-xs italic text-fortin-green-dark/60 md:text-sm">
                {partner.name}
              </p>
            );

            return partner.url ? (
              <a
                href={partner.url}
                target="_blank"
                rel="noopener noreferrer"
                class={cardClass}
                aria-label={`Site web de ${partner.name}`}
              >
                {inner}
              </a>
            ) : (
              <div class={cardClass}>{inner}</div>
            );
          })
        }
      </div>
    </div>
  </section>
</Base>
