---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
  showFooter?: boolean;
}

const {
  title,
  description = "Fortin, association audiovisuelle dédiée à la mémoire et au patrimoine.",
  ogImage = "/og-image.png",
  noindex = false,
  showFooter = true,
} = Astro.props;

const fullTitle = title.toLowerCase().includes("fortin")
  ? title
  : `${title} · Fortin`;
const siteBase = Astro.site ?? Astro.url;
const canonicalURL = new URL(Astro.url.pathname, siteBase);
const ogImageURL = new URL(ogImage, siteBase);

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "NGO",
  name: "Fortin",
  alternateName: "Association Fortin",
  url: new URL("/", siteBase).href,
  logo: new URL("/logo-fortin.png", siteBase).href,
  image: new URL("/og-image.png", siteBase).href,
  description:
    "Fortin, fondée en 2021, est une association audiovisuelle qui œuvre comme un rempart contre l'oubli : elle produit des documentaires sur la mémoire et le patrimoine, en tissant un lien entre les générations.",
  foundingDate: "2021",
  areaServed: "Franche-Comté, France",
  sameAs: [
    "https://www.facebook.com/profile.php?id=100085837425073",
    "https://www.instagram.com/fortin_projet/",
    "https://www.youtube.com/@fortin_projet",
    "https://www.tiktok.com/@fortin_projet",
    "https://www.linkedin.com/in/fortin-projet-572762296",
    "https://vimeo.com/user210486084",
  ],
  contactPoint: [
    {
      "@type": "ContactPoint",
      contactType: "Présidence",
      email: "thibautgarcia25300@gmail.com",
      telephone: "+33637691768",
    },
    {
      "@type": "ContactPoint",
      contactType: "Vice-présidence",
      email: "germain-mat25@orange.fr",
      telephone: "+33602321720",
    },
  ],
};
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Fortin" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Logo de l'association Fortin" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
  </head>
  <body class="flex min-h-screen flex-col bg-fortin-beige text-fortin-green-dark">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    {showFooter && <Footer />}
  </body>
</html>
