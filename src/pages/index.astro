---
export const prerender = true;

import Base from "../layouts/Base.astro";

const pillars = [
  {
    title: "Audiovisuel",
    description:
      "Documentaires, films, séries — l'image et le son comme vecteurs de transmission, pour donner une voix aux témoins de l'histoire.",
  },
  {
    title: "Histoire",
    description:
      "De la guerre d'Algérie à Verdun, nous explorons les événements qui ont façonné notre époque, à travers des récits poignants et des sources d'archives.",
  },
  {
    title: "Mémoire",
    description:
      "Un rempart contre l'oubli. Préserver et transmettre la mémoire collective, en tissant un lien indissoluble entre les générations.",
  },
];

---

<Base
  title="Accueil"
  description="Fortin, association audiovisuelle française dédiée à la mémoire collective. Documentaires, témoignages d'anciens combattants, projets sur l'histoire et le patrimoine."
>
  <section class="relative bg-fortin-green-dark px-8 py-20 text-fortin-beige md:px-16 md:py-32">
    <div class="mx-auto max-w-5xl">
      <p class="font-display text-lg italic md:text-xl">
        «&nbsp;On cherche à ne pas oublier&nbsp;»
      </p>
      <h1 class="mt-6 font-display text-5xl leading-tight font-bold md:text-7xl lg:text-8xl">
        Le rempart contre l'oubli
      </h1>
      <p class="mt-8 max-w-2xl text-base leading-relaxed md:text-lg">
        Fortin est une association audiovisuelle française dédiée à la mémoire
        collective. Nous donnons une voix aux témoins oubliés de la grande
        histoire et préservons, par le film, les fragments d'un passé qui aurait
        pu être progressivement effacé.
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href="/realisations"
          class="inline-flex items-center justify-center rounded-sm bg-fortin-beige px-6 py-3 font-medium text-fortin-green-dark transition-opacity hover:opacity-80"
        >
          Voir nos films
        </a>
        <a
          href="/fortin"
          class="inline-flex items-center justify-center rounded-sm border border-fortin-beige px-6 py-3 font-medium transition-opacity hover:opacity-80"
        >
          Découvrir Fortin
        </a>
      </div>
    </div>
  </section>

  <section class="px-8 py-16 md:px-16 md:py-24">
    <div class="mx-auto max-w-7xl">
      <div class="mx-auto max-w-3xl text-center">
        <p class="text-sm font-medium tracking-widest uppercase opacity-70">
          Dernière réalisation
        </p>
        <h2 class="mt-4 font-display text-3xl font-bold md:text-5xl">
          Un Portrait du Temps
        </h2>
        <p class="mt-2 text-lg italic">01 — Nos Grands-parents</p>
        <p class="mt-6 text-base leading-relaxed md:text-lg">
          Une série documentaire qui met en lumière les visions à la fois
          semblables et différentes des hommes et des femmes de l'ancienne et de
          la nouvelle générations, à travers 8 épisodes thématiques.
        </p>
      </div>

      <div class="mt-10 aspect-video w-full overflow-hidden bg-fortin-green-dark md:mt-12">
        <iframe
          src="https://player.vimeo.com/video/882193861"
          class="h-full w-full"
          title="Un Portrait du Temps — Épisode 1"
          allow="autoplay; fullscreen; picture-in-picture"
          loading="lazy"
          allowfullscreen></iframe>
      </div>

      <div class="mt-8 text-center">
        <a
          href="/realisations"
          class="inline-flex items-center gap-2 font-medium underline underline-offset-4 transition-opacity hover:opacity-70"
        >
          Voir toutes nos réalisations
          <svg
            class="h-4 w-4"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <section class="bg-fortin-green-dark px-8 py-16 text-fortin-beige md:px-16 md:py-24">
    <div class="mx-auto max-w-7xl">
      <h2 class="text-center font-display text-3xl font-bold md:text-5xl">
        Audiovisuel · Histoire · Mémoire
      </h2>
      <div class="mt-12 grid gap-10 md:grid-cols-3 md:gap-12">
        {
          pillars.map((pillar) => (
            <div class="border-t border-fortin-beige/30 pt-6">
              <h3 class="font-display text-2xl font-bold">{pillar.title}</h3>
              <p class="mt-4 text-sm leading-relaxed md:text-base">
                {pillar.description}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-fortin-green-dark px-8 py-16 text-fortin-beige md:px-16 md:py-24">
    <div class="mx-auto flex max-w-5xl flex-col items-start gap-8 md:flex-row md:items-center md:justify-between">
      <div>
        <h2 class="font-display text-3xl font-bold md:text-4xl">
          Soutenez Fortin
        </h2>
        <p class="mt-4 max-w-xl text-base md:text-lg">
          Aidez-nous à faire vivre l'association. En faisant une donation, vous
          nous aidez à entretenir l'histoire qui vous passionne.
        </p>
      </div>
      <a
        href="/soutenir"
        class="inline-flex shrink-0 items-center justify-center rounded-sm bg-fortin-beige px-6 py-3 font-medium text-fortin-green-dark transition-opacity hover:opacity-80"
      >
        Faire un don
      </a>
    </div>
  </section>
</Base>
