---
export const prerender = true;

import Base from "../layouts/Base.astro";
import TestimonialCarousel from "../components/TestimonialCarousel.astro";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import afficheMemoire from "../assets/images/Affiche Mémoire d'appelé.jpg";
import couvertureCarnet from "../assets/images/couverture_livret.png";
import carnetIllu1 from "../assets/images/illu1.png";
import carnetIllu2 from "../assets/images/illu2.png";
import carnetIllu3 from "../assets/images/illu3.png";

interface Project {
  title: string;
  subtitle?: string;
  description?: string;
  credits: Record<string, string>;
  technical: Record<string, string>;
  productionDate: string;
  videoEmbed?: { provider: "vimeo" | "youtube"; id: string };
  hasPoster?: boolean;
  posterImage?: ImageMetadata;
  posterAlt?: string;
  gallery?: { src: ImageMetadata; alt: string }[];
}

const projects: Project[] = [
  {
    title: "Un Portrait du Temps",
    subtitle: "Une série documentaire en 8 épisodes · 32 témoignages",
    description:
      "Un Portrait du Temps est une série documentaire mettant en lumière les visions à la fois semblables et différentes des hommes et des femmes de l'ancienne et de la nouvelle générations. Au travers de 8 épisodes thématiques (Nos Grands-parents, l'Éducation, le Travail, les Loisirs, la Santé, la Guerre, La Société, Nos Petits-enfants), cette série explore les temps qui figurent la vie de chaque génération. Le tournage s'est achevé le 23 février 2025 ; la postproduction est en cours, pour une finalisation prévue au printemps 2026.",
    credits: {
      "Écrit, monté et réalisé par": "Thibaut Garcia",
      "Produit par": "Gabin Parisot",
      "Entretiens dirigés par": "Marie Ferreux",
      "Voix off interprétée par": "Manuella Le Bruchec",
      "Musique composée par": "Théo Henrion",
      "Dessins d'animation réalisés par":
        "Joy Chaleroux, Yukiko Pinard & Diana Ionasku",
      "Prise de son par":
        "Gwenvaël Le Faucheur, Théo Henrion & Matthias Germain",
      "Archivage par": "Matthias Germain & Thibaut Garcia",
      "Making-of réalisé par": "Ilhan Köken",
      "Assistanat de production":
        "Édouard Lemoine, Charlotte Chauvel, Nina Cretet & Thomas Germain",
      "Avec le soutien de": "Communes de Houtaud et Pontarlier",
      "En collaboration avec": "Image'Est",
    },
    technical: {
      Genre: "Série Documentaire",
      Langue: "Français",
      Durée: "8 épisodes entre 20 et 25 minutes",
      Couleurs: "Couleurs & noir et blanc",
      Témoignages: "32 témoins",
    },
    productionDate: "Postproduction · Finalisation printemps 2026",
    videoEmbed: { provider: "vimeo", id: "882193861" },
  },
  {
    title: "Carnet d'une libération",
    subtitle: "Recueil de témoignages · Libération de Pontarlier",
    description:
      "Court livret de témoignages dont l'objectif est de rendre l'histoire de la libération de Pontarlier accessible à toutes les tranches d'âge. L'ouvrage repose sur des entretiens menés avec des anciens ayant vécu cet événement durant leur jeunesse : où étaient-ils, que faisaient-ils, avec qui, quelles histoires ont-ils transmises ? Pensé à la fois comme un objet mémoriel et un objet divertissant, le Carnet est le premier projet papier abouti par l'association ; il ouvre une nouvelle catégorie de production aux côtés du film documentaire.",
    credits: {
      "Coordination éditoriale": "Thibaut Garcia, Joy Chaleroux",
      "Recueil des témoignages":
        "L'association Fortin et la Ville de Pontarlier",
      Témoins:
        "Denise Grenon, Madeleine Maugain, Guy Cuby, Suzanne Meunier, Aïssa Youness, Thérèse Jeandroz, et une jeune fille de 24 ans",
      Rédaction: "Marie Ferreux",
      Illustrations: "Louise Reutenauer",
      "Mise en page": "Héléna Della Posta",
      "Avec le soutien de":
        "La Ville de Pontarlier et la commune de Houtaud",
      Remerciements:
        "Marie Borne (directrice des Archives municipales de Pontarlier) et Julie Jacquet (chargée de communication numérique de la Ville de Pontarlier)",
    },
    technical: {
      Format: "Livret papier",
      Langue: "Français",
      Lancement: "9 mai 2026 · Médiathèque de Pontarlier",
    },
    productionDate: "Août 2025",
    hasPoster: true,
    posterImage: couvertureCarnet,
    posterAlt: "Couverture du Carnet d'une libération",
    gallery: [
      { src: carnetIllu1, alt: "Illustration du Carnet d'une libération" },
      { src: carnetIllu2, alt: "Illustration du Carnet d'une libération" },
      { src: carnetIllu3, alt: "Illustration du Carnet d'une libération" },
    ],
  },
  {
    title: "Tranchées du ciel",
    description:
      "Réalisé à l'occasion de l'anniversaire de l'armistice du 11 novembre 2022, Tranchées du ciel retrace l'histoire tumultueuse de la construction mémorielle de la première guerre mondiale et de la bataille de Verdun. Documents d'archives, interviews de spécialistes et images inédites des monuments et des ruines actuelles du champ de bataille de Verdun vous plongent dans cette histoire centenaire d'une Mémoire française et européenne commune.",
    credits: {
      "Écrit, monté et réalisé par": "Thibaut Garcia",
      "Produit par": "Gabin Parisot & Edouard Lemoine",
      "Musique composée par": "Théo Henrion",
      "Voix off interprétée par":
        "Bernard Kordylas, Xavier Garcia & Anthony Authier",
      "Interviews de": "Nicolas Barrot, Nicolas Czubak & Olivier Girard",
      "Prise de son par": "Joy Chaleroux & Ilhan Köken",
      "Colorisation graphique de": "Joy Chaleroux & Ilhan Köken",
      "Archivage par": "Matthias Germain",
    },
    technical: {
      Genre: "Film Documentaire",
      Langue: "Français",
      Durée: "25 minutes",
      Couleurs: "Couleurs & noir et blanc",
    },
    productionDate: "Novembre 2022",
    videoEmbed: { provider: "youtube", id: "LIgkJo1u6jA" },
    hasPoster: true,
    posterAlt: "Affiche du film Tranchées du ciel",
  },
  {
    title: "Mémoire d'appelé",
    subtitle: "Témoignage d'un appelé du dernier conflit français",
    description:
      "Mémoire d'appelé retrace la guerre d'Algérie à travers le regard de ces jeunes appelés franc-comtois. Nourri de la petite histoire à la grande histoire, ce documentaire présente, 60 ans après la fin du conflit, les témoignages d'anciens combattants à son petit-fils. Présenté dans le milieu scolaire et universitaire, ce documentaire se présente comme un outil didactique abordant la guerre d'Algérie dans sa globalité et du point de vue d'un de ses combattants français.",
    credits: {
      "Écrit, réalisé et monté par": "Thibaut Garcia",
      "Témoignage de": "Gabriel Ferreux",
      "Voix off de": "Gabin Parisot et Thibaut Garcia",
      "Musique de": "Gilles Le Faucheur",
      "Animation de": "Ilhan Köken",
      "Conseil historique": "Anthony Authier",
      "Ingénieur du son": "Gwenvaël Le Faucheur",
    },
    technical: {
      Genre: "Film Documentaire",
      Langue: "Français",
      Durée: "32 minutes",
      Couleurs: "Couleurs & noir et blanc",
      Sélection: "Lumières d'Afrique 2021",
    },
    productionDate: "Juillet 2021",
    hasPoster: true,
    posterImage: afficheMemoire,
    posterAlt: "Affiche du film Mémoire d'appelé",
  },
];
---

<Base
  title="Nos réalisations"
  description="Découvrez les productions de Fortin : Un Portrait du Temps (série documentaire), Tranchées du ciel (Verdun), Mémoire d'appelé (guerre d'Algérie) et Carnet d'une libération (Pontarlier)."
>
  <header class="px-8 pt-8 md:px-16 md:pt-12">
    <div class="mx-auto max-w-7xl">
      <h1 class="font-display text-4xl font-bold md:text-5xl">
        Nos Réalisations
      </h1>
      <hr class="mt-4 border-fortin-green-dark/30" />
      <p class="mx-auto mt-8 max-w-3xl text-center text-base md:text-lg">
        Les réalisations audiovisuelles de Fortin témoignent d'une passion
        partagée pour l'histoire et la mémoire, portée collectivement par chaque
        membre de l'association.
      </p>
    </div>
  </header>

  <div class="mt-10 md:mt-12">
    <TestimonialCarousel />
  </div>

  <div class="space-y-20 px-8 py-16 md:space-y-28 md:px-16 md:py-20">
    {
      projects.map((project, idx) => (
        <article class="mx-auto max-w-7xl">
          <div
            class:list={[
              "grid gap-10 md:gap-12",
              project.hasPoster && "md:grid-cols-2",
            ]}
          >
            {project.hasPoster && (
              <div>
                {project.posterImage ? (
                  <Image
                    src={project.posterImage}
                    alt={project.posterAlt ?? `Affiche de ${project.title}`}
                    class="aspect-2/3 w-full object-cover"
                    width={800}
                    height={1200}
                    loading="lazy"
                  />
                ) : (
                  <div
                    class="aspect-2/3 w-full bg-fortin-green-dark"
                    aria-label={project.posterAlt}
                  >
                    <div class="flex h-full items-center justify-center p-8 text-center text-fortin-beige">
                      <div>
                        <p class="font-display text-2xl font-bold">
                          {project.title}
                        </p>
                        <p class="mt-4 text-sm opacity-70">[Affiche à venir]</p>
                      </div>
                    </div>
                  </div>
                )}
              </div>
            )}

            <div>
              <h2 class="font-display text-3xl font-bold md:text-4xl">
                {project.title}
              </h2>
              {project.subtitle && (
                <p class="mt-2 text-lg italic">{project.subtitle}</p>
              )}

              {project.description && (
                <p class="mt-6 text-sm leading-relaxed md:text-base">
                  {project.description}
                </p>
              )}

              <dl class="mt-8 space-y-3 text-sm">
                <dt class="font-display text-lg font-bold">Crédits</dt>
                <dd>
                  <ul class="space-y-1">
                    {Object.entries(project.credits).map(([role, person]) => (
                      <li>
                        <span class="opacity-70">{role}</span> : {person}
                      </li>
                    ))}
                  </ul>
                </dd>
              </dl>

              <dl class="mt-6 grid grid-cols-2 gap-4 text-sm">
                <div>
                  <dt class="font-display text-lg font-bold">
                    Données techniques
                  </dt>
                  <dd class="mt-2">
                    <ul class="space-y-1">
                      {Object.entries(project.technical).map(([k, v]) => (
                        <li>
                          <span class="opacity-70">{k}</span> : {v}
                        </li>
                      ))}
                    </ul>
                  </dd>
                </div>
                <div>
                  <dt class="font-display text-lg font-bold">
                    Date de fin de production
                  </dt>
                  <dd class="mt-2">{project.productionDate}</dd>
                </div>
              </dl>
            </div>
          </div>

          {project.videoEmbed && (
            <div class="mt-10 aspect-video w-full overflow-hidden bg-fortin-green-dark md:mt-12">
              {project.videoEmbed.provider === "vimeo" ? (
                <iframe
                  src={`https://player.vimeo.com/video/${project.videoEmbed.id}`}
                  class="h-full w-full"
                  title={`Lecteur vidéo : ${project.title}`}
                  allow="autoplay; fullscreen; picture-in-picture"
                  loading="lazy"
                  allowfullscreen
                />
              ) : (
                <iframe
                  src={`https://www.youtube-nocookie.com/embed/${project.videoEmbed.id}`}
                  class="h-full w-full"
                  title={`Lecteur vidéo : ${project.title}`}
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  loading="lazy"
                  allowfullscreen
                />
              )}
            </div>
          )}

          {project.gallery && project.gallery.length > 0 && (
            <div class="mt-10 md:mt-12">
              <p class="text-sm font-medium tracking-widest uppercase opacity-70">
                Illustrations
              </p>

              <div class="mt-4 flex flex-col items-center gap-4 md:flex-row md:flex-wrap md:justify-center md:gap-6">
                {project.gallery.map((img) => (
                  <Image
                    src={img.src}
                    alt={img.alt}
                    class="w-full md:h-72 md:w-auto"
                    width={600}
                    height={600}
                    loading="lazy"
                  />
                ))}
              </div>
            </div>
          )}

          {idx < projects.length - 1 && (
            <hr class="mt-20 border-fortin-green-dark/30 md:mt-24" />
          )}
        </article>
      ))
    }
  </div>
</Base>
