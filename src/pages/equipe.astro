---
import Base from "../layouts/Base.astro";
import { Image } from "astro:assets";
import matthiasPhoto from "../assets/team/matthias.jpg";

const members = [
  {
    name: "Thibaut Garcia",
    role: "Réalisateur",
    bio: "Crée l'association Fortin avec Gabin et d'autres de mes amis c'est avéré comme une évidence à la suite de la production du documentaire Mémoire d'appelé. Chacun de nos projet sont une occasions pour moi, comme pour l'ensemble de l'équipe, de ce retrouver et de passer du temps ensemble pour travailler sur la Mémoire. Les productions que je réalise dans le cadre de Fortin sont l'occasion pour moi de mettre mes compétence au service d'un projet commun portant sur une thématique mémorielle qui m'est très chère.",
  },
  {
    name: "Gabin Parisot",
    role: "Producteur",
    bio: "FORTIN est beaucoup de choses. Pour moi, FORTIN est un devoir de mémoire, d'histoire, même un devoir citoyen, qui se manifeste par une création audio-visuelle qui elle même met en valeur le lien intergénérationnel. FORTIN est par dessus tout, un projet qui permet de créer du lien et de faire de nouvelles connexions entre les générations, les opinions, les expériences. FORTIN est pour nous, l'occasion de vivre une expérience forte et enrichissante entre amis et coéquipiers, issus de différents horizons, de différents cursus scolaires, aux compétences et aux connaissances multiples. Bref, FORTIN est beaucoup de choses.",
  },
  {
    name: "Théo Henrion",
    role: "Compositeur",
    bio: "Quand Thibaut m'a proposé de participer au projet, j'ai directement accepté. Ce qu'il y a de plus beau dans la création, c'est la passion qui anime et rassemble chaque personne participant à l'élaboration d'un projet. Avoir la chance de pouvoir y contribuer et à mon tour ressentir une telle émotion, c'est ce qui me motive à composer la musique du projet. C'est également une expérience qui me permet de découvrir un peu plus le vaste monde de l'audiovisuel.",
  },
  {
    name: "Gwenvaël Lefaucheur",
    role: "Ingénieur son",
    bio: "Ce qui me motive à participer au projet, c'est l'expérience. L'expérience de découvrir encore plus le milieu audiovisuel et l'envie de développer mes compétences en tant qu'ingénieur son, entouré d'amis qui apportent chacun quelque chose de spécial au projet en général. Surtout, c'est une passion que j'ai pour l'histoire et pour les anecdotes de l'ancienne génération, et qui, ici, prend forme sous un angle différent des livres et des enseignements, un angle que j'apprécie particulièrement.",
  },
  {
    name: "Joy Chaleroux",
    role: "Animatrice 2D et 3D",
    bio: "Depuis très jeune j'écoute avec la plus grande attention les histoires du temps d'avant de ma grand-mère. Malgré l'écart générationnel, j'ai toujours l'impression qu'elle me rappelle « la vraie vie ». Le projet m'a tout de suite conquise car étant attaché au devoir de mémoire et avec l'ambition de me dépasser dans mon travail, c'était pour moi une évidence. Je vois également dans ce projet l'opportunité d'apprendre de nouvelles choses et de travailler en équipe, qui plus est avec des amis.",
  },
  {
    name: "Matthias Germain",
    role: "Concepteur web & Ingénieur son",
    bio: "Intéressé et concerné par le devoir de mémoire, Fortin est un projet avec un sens profond, qui permet à une équipe de faire vivre ses compétences, aboutissant à restituer la mémoire de nos anciens et la partager aux générations présentes et futures.",
  },
  {
    name: "Pierre Clerc",
    role: "Concepteur web",
    bio: "Fortin c'est avant tout créer du lien entre nos différentes générations, et surtout un devoir de mémoire. Je pense qu'il est important de se souvenir de ce qu'ont fait nos aînés, et d'apprendre à les comprendre et les connaître. C'est surtout pour cela que j'aime beaucoup ce projet. De plus, je peux mettre à profit mes compétences pour Fortin, en réalisant son site WEB.",
  },
  {
    name: "Édouard Lemoine",
    role: "Régisseur",
    bio: "J'ai toujours été intéressé par la mémoire des conflits, qu'ils soient récents ou lointains. Je trouve qu'il faut continuer à entretenir la mémoire de ceux-ci, que ce soit à travers des cérémonies, des mémoriaux, des musées… Mais il faut aussi savoir retranscrire la mémoire avec de nouveaux outils comme YouTube ou les réseaux sociaux… C'est pour ça que j'ai tout de suite voulu faire partie de Fortin.",
  },
  {
    name: "Thomas Germain",
    role: "Régisseur",
    bio: "Thibaut et Gabin sont de bon amis, c'est naturellement que je me suis intéressé à leur projet, et quand j'ai vu leur envie et la qualité des projets qu'ils ont déjà réalisé comme « Mémoire d'appelé », qui en plus traite d'un sujet qui m'intéresse particulièrement, j'ai forcément voulu aider avec ce que je pouvais apporter pour les projets à venir, et c'est avec plaisir que je continue.",
  },
  {
    name: "Marie Ferreux",
    role: "Responsable interview",
    bio: "S'investir dans le projet « Fortin », est un moyen pour moi d'accomplir un devoir de mémoire plus qu'important de nos jours tout en participant à une expérience stimulante intellectuellement et humainement. L'association Fortin, c'est aussi le désir de réaliser des projets aboutis, utiles et intéressants tout en apprenant à sublimer les compétences de chacun dans un but commun.",
  },
  {
    name: "Nina Cretet",
    role: "Assistante Production",
    bio: "Ce projet traduit une véritable envie d'apprendre, de comprendre et de restituer un morceau de notre culture et de notre histoire. C'est pourquoi il m'était important d'y participer, même de loin. La dimension de partage, de transmission des valeurs le rend d'autant plus intéressant.",
  },
  {
    name: "Ilhan Koken",
    role: "Réalisateur making off",
    bio: "FORTIN, c'est le plaisir de travailler avec des amis, pour un devoir de mémoire important et nécessaire, et l'objectif de se professionnaliser plus encore dans l'audio visuel.",
  },
  {
    name: "Charlotte",
    role: "Responsable interview",
    bio: "Je me rappelle les cours d'Histoire à rallonge au Lycée, les faits à apprendre par cœur face à notre feuille. Le projet Fortin, c'est mettre tout cela en images, documenter concrètement tous ces concepts… mais aussi pouvoir apprendre de ces personnes qui font l'histoire à leur échelle, peu importe leur âge ! En tant qu'étudiante en journalisme, je ne pouvais que rejoindre ce beau projet, enrichissant techniquement, comme intellectuellement. J'espère que vous en apprendrez beaucoup grâce à nous !",
  },
  {
    name: "Manuella",
    role: "Assistante Production",
    bio: "Le talent au service de l'histoire ! Ce serait selon moi un bon résumé de Fortin, une association où chacun joue un rôle important et peut exprimer ses savoir-faire. Je vois dans ce projet l'occasion d'être utile et de prouver que « jeunesse » n'est pas synonyme de désintérêt pour la culture et notre histoire. Nous sommes le résultat de celle de nos parents, grands-parents et arrières grand-parents, je suis alors heureuse que des personnes, de mon âge qui plus est, m'offrent la possibilité de participer à la mémoire !",
  },
];
---

<Base
  title="Notre équipe"
  description="L'équipe de Fortin : 14 passionnés issus de différents domaines, réunis par le devoir de mémoire pour produire des documentaires sur l'histoire collective."
>
  <section class="px-8 py-12 md:px-16 md:py-16">
    <div class="mx-auto max-w-7xl">
      <header class="border-b border-fortin-green-dark/30 pb-8">
        <h1 class="font-display text-4xl font-bold md:text-5xl">Notre Équipe</h1>
      </header>

      <p class="mx-auto mt-10 max-w-3xl text-center text-base md:text-lg">
        L'équipe de Fortin est composée d'individus passionnés et talentueux
        provenant de différents domaines d'études. Réunis par leur engagement
        envers le devoir de mémoire, ils travaillent ensemble pour donner vie à
        des projets aboutis, stimulants intellectuellement et humainement.
      </p>

      <div class="mt-12 grid gap-8 md:grid-cols-3 md:gap-10">
        {
          members.map((m) => (
            <article class="flex flex-col">
              <div class="aspect-2/3 overflow-hidden bg-fortin-green-dark">
                <Image
                  src={matthiasPhoto}
                  alt={`Portrait de ${m.name}`}
                  class="h-full w-full object-cover"
                  width={600}
                  height={900}
                />
              </div>
              <div class="mt-4">
                <h2 class="font-display text-lg font-bold tracking-wider uppercase">
                  {m.name}
                </h2>
                <p class="mt-1 text-sm italic">{m.role}</p>
                <p class="mt-3 text-sm leading-relaxed">{m.bio}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>
</Base>
