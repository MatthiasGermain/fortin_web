---
const navItems = [
  { label: "Qu'est-ce que Fortin ?", href: "/fortin" },
  { label: "Nos réalisations", href: "/realisations" },
  { label: "Notre équipe", href: "/equipe" },
  { label: "Nous contacter", href: "/contact" },
  { label: "Nous soutenir", href: "/soutenir" },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-40 bg-fortin-beige px-8 py-6 md:px-16 md:py-8">
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-8">
    <a href="/" class="flex items-center gap-3" aria-label="Accueil Fortin">
      <img
        src="/logo-fond-vert.png"
        alt="Logo Fortin"
        class="h-12 w-12 rounded-full"
      />
      <span class="font-display text-xl font-bold tracking-wider">FORTIN</span>
    </a>

    <nav>
      <ul class="hidden gap-8 text-sm md:flex">
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={[
                  "transition-opacity hover:opacity-70",
                  currentPath === item.href && "underline underline-offset-4",
                ]}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>

      <button
        type="button"
        id="mobile-menu-button"
        class="md:hidden inline-flex h-10 w-10 items-center justify-center rounded-sm transition-opacity hover:opacity-70"
        aria-label="Ouvrir le menu"
        aria-controls="mobile-menu"
        aria-expanded="false"
      >
        <svg
          class="h-6 w-6"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </nav>
  </div>
</header>

<div
  id="mobile-menu"
  class="fixed inset-0 z-50 translate-x-full transform transition-transform duration-300 ease-in-out bg-fortin-green-dark text-fortin-beige md:hidden"
  aria-hidden="true"
>
  <div class="flex h-full flex-col px-8 py-6">
    <div class="flex items-center justify-between">
      <span class="font-display text-xl font-bold tracking-wider">FORTIN</span>
      <button
        type="button"
        id="mobile-menu-close"
        class="inline-flex h-10 w-10 items-center justify-center rounded-sm transition-opacity hover:opacity-70"
        aria-label="Fermer le menu"
      >
        <svg
          class="h-6 w-6"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <nav class="mt-8 flex flex-1 flex-col justify-center sm:mt-16">
      <ul class="space-y-3 text-center sm:space-y-5">
        {
          navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={[
                  "block py-2 font-display text-xl transition-opacity hover:opacity-70 sm:text-2xl",
                  currentPath === item.href && "underline underline-offset-8",
                ]}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</div>

<script>
  const button = document.getElementById("mobile-menu-button");
  const closeButton = document.getElementById("mobile-menu-close");
  const menu = document.getElementById("mobile-menu");

  const open = () => {
    menu?.classList.remove("translate-x-full");
    menu?.setAttribute("aria-hidden", "false");
    button?.setAttribute("aria-expanded", "true");
    document.body.classList.add("overflow-hidden");
  };

  const close = () => {
    menu?.classList.add("translate-x-full");
    menu?.setAttribute("aria-hidden", "true");
    button?.setAttribute("aria-expanded", "false");
    document.body.classList.remove("overflow-hidden");
  };

  button?.addEventListener("click", open);
  closeButton?.addEventListener("click", close);

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") close();
  });

  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", close);
  });
</script>
